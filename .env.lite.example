# ===== Редакция LITE (для одного тренера) =====
EDITION=lite
# Lite работает на SQLite — отдельная БД не нужна
DATABASE_URL=sqlite+aiosqlite:////data/badminton.db

# ===== Telegram (обязательно) =====
TG_TOKEN=
TG_MODE=polling

# ===== ВКонтакте (необязательно) =====
VK_TOKEN=
RUN_VK_POLLING=false

# ===== Прочее =====
TIMEZONE=Europe/Moscow
LOG_DIR=/data/logs
# Секрет JWT в Lite не используется (админки нет), но переменная должна быть
JWT_SECRET=lite-not-used
