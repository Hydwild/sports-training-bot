# ===== База данных =====
# Локальная разработка (по умолчанию) — SQLite:
DATABASE_URL=sqlite+aiosqlite:///./badminton.db
# Прод — PostgreSQL (так задаётся в docker-compose автоматически):
# DATABASE_URL=postgresql+asyncpg://badminton:badminton@db:5432/badminton

# ===== FastAPI =====
API_HOST=0.0.0.0
API_PORT=8000
# Токен для защиты служебных эндпойнтов /api (заголовок X-Admin-Token)
ADMIN_API_TOKEN=change-me
# Публичный URL для webhook (если используете webhook), напр. https://bot.example.com
PUBLIC_BASE_URL=

# ===== Telegram =====
TG_TOKEN=
# polling (по умолчанию) или webhook
TG_MODE=polling
# Секрет webhook (если TG_MODE=webhook)
TG_WEBHOOK_SECRET=

# ===== ВКонтакте =====
VK_TOKEN=
RUN_VK_POLLING=false
# Для Callback API (webhook VK):
VK_CONFIRMATION=
VK_SECRET=

# ===== Прочее =====
TIMEZONE=Europe/Moscow
LOG_DIR=logs

# ===== Безопасность / JWT =====
# ОБЯЗАТЕЛЬНО смените в проде на длинную случайную строку
# Сгенерируйте: openssl rand -base64 32  (иначе Pro-сервис не стартует)
JWT_SECRET=

# ===== Админка (вход через Telegram) =====
TG_BOT_USERNAME=
# dev-вход без Telegram — ТОЛЬКО для локальной отладки
ADMIN_DEV_LOGIN=false

# ===== Платежи =====
# ЮKassa (рабочий провайдер)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Stripe (каркас)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
