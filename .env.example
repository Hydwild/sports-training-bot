# ===== База данных =====
# Локальная разработка (по умолчанию) — SQLite:
DATABASE_URL=sqlite+aiosqlite:///./badminton.db
# Прод — PostgreSQL (так задаётся в docker-compose автоматически):
# DATABASE_URL=postgresql+asyncpg://badminton:badminton@db:5432/badminton

# ===== FastAPI =====
API_HOST=0.0.0.0
API_PORT=8000
# Токен для защиты служебных эндпойнтов /api (заголовок X-Admin-Token)
ADMIN_API_TOKEN=change-me
# Публичный URL для webhook (если используете webhook), напр. https://bot.example.com
PUBLIC_BASE_URL=

# ===== Telegram =====
TG_TOKEN=
# polling (по умолчанию) или webhook
TG_MODE=polling
# Секрет webhook (если TG_MODE=webhook)
TG_WEBHOOK_SECRET=

# ===== ВКонтакте =====
VK_TOKEN=
RUN_VK_POLLING=false
# Для Callback API (webhook VK):
VK_CONFIRMATION=
VK_SECRET=

# ===== Прочее =====
TIMEZONE=Europe/Moscow
LOG_DIR=logs

# ===== Безопасность / JWT =====
# ОБЯЗАТЕЛЬНО смените в проде на длинную случайную строку
# Сгенерируйте: openssl rand -base64 32  (иначе Pro-сервис не стартует)
JWT_SECRET=

# --- Ключи шифрования персональных данных (см. app/core/phones.py) ---
# Телефоны веб-клиентов хранятся зашифрованными, а ищутся по HMAC-индексу.
# PHONE_ENC_KEY — выделенный ключ (версия v1). Пусто — используется
# исторический ключ, выведенный из JWT_SECRET (версия jwt).
#
# ВАЖНО для существующей базы: не задавайте PHONE_ENC_KEY «на ходу».
# Порядок: деплой кода -> добавить PHONE_ENC_KEY и PHONE_KEYRING со старым
# ключом -> python -m scripts.migrate_phone_keys --dry-run -> --apply ->
# --verify -> и только потом убирать связку и ротировать JWT_SECRET.
# Ключ хранить ОТДЕЛЬНО от резервных копий: копия зашифрована им же.
PHONE_ENC_KEY=
# Связка прежних ключей на время перехода: ver:secret,ver:secret
# Например: jwt:<прежнее значение JWT_SECRET>
PHONE_KEYRING=
# Ключ шифрования токенов Telegram/VK клубов (см. app/core/bot_tokens.py).
# Отдельный от JWT и от ключа телефонов. Обязателен для Pro: без него
# токен клуба нельзя сохранить. Хранить ВНЕ Railway и вне резервных копий.
BOT_TOKEN_ENC_KEY=
# Связка прежних ключей токенов на время замены: ver:secret,ver:secret
BOT_TOKEN_KEYRING=
# Ключ шифрования резервных копий (см. app/services/backup.py). Копия
# уходит в Telegram — без ключа она не отправляется вовсе. Хранить
# ОТДЕЛЬНО от самих копий: ключ рядом с копией не защищает ни от чего.
BACKUP_ENC_KEY=
# Кому доверять заголовок X-Forwarded-For (uvicorn --forwarded-allow-ips).
# Пусто — не доверять никому: подделать адрес нельзя, но за обратным прокси
# все посетители будут выглядеть одинаково и лимит запросов станет общим.
# На Railway адрес прокси динамический — там нужно "*".
TRUSTED_PROXIES=
# Одноразовое разрешение на 'alembic stamp head' для legacy-базы, у которой
# схему создал create_all до появления alembic (см. app/db/pre_migrate.py).
# В обычном деплое НЕ задавать: без флага упавшая миграция честно
# останавливает выкат. Ставить 1 только осознанно и снимать после успеха.
ALLOW_LEGACY_STAMP=





# ===== Админка (вход через Telegram) =====
TG_BOT_USERNAME=
# dev-вход без Telegram — ТОЛЬКО для локальной отладки
ADMIN_DEV_LOGIN=false

# ===== Платежи =====
# ЮKassa (рабочий провайдер)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Stripe (каркас)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
