# ===== Редакция PRO (для клуба) =====
EDITION=pro
# Pro работает на PostgreSQL (поднимается в docker-compose)
DATABASE_URL=postgresql+asyncpg://badminton:badminton@db:5432/badminton

# ===== Telegram =====
TG_TOKEN=
TG_MODE=polling
TG_WEBHOOK_SECRET=
TG_BOT_USERNAME=

# ===== ВКонтакте =====
VK_TOKEN=
RUN_VK_POLLING=false
VK_CONFIRMATION=
VK_SECRET=

# ===== Безопасность =====
# ОБЯЗАТЕЛЬНО: случайная строка ≥16 символов, иначе сервис не стартует.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
ADMIN_API_TOKEN=
# dev-вход в админку без Telegram — только для отладки
ADMIN_DEV_LOGIN=false

# ===== Платежи (ЮKassa) =====
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Stripe (каркас)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== Публичный адрес (для webhook) =====
PUBLIC_BASE_URL=

# ===== Прочее =====
TIMEZONE=Europe/Moscow
LOG_DIR=/data/logs
