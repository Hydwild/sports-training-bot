# ===== Редакция PRO (для клуба) =====
EDITION=pro
# Pro работает на PostgreSQL (поднимается в docker-compose)
DATABASE_URL=postgresql+asyncpg://badminton:badminton@db:5432/badminton

# ===== Telegram =====
TG_TOKEN=
TG_MODE=polling
TG_WEBHOOK_SECRET=
TG_BOT_USERNAME=

# ===== ВКонтакте =====
VK_TOKEN=
RUN_VK_POLLING=false
VK_CONFIRMATION=
VK_SECRET=

# Master-secret для уникальных секретов webhook каждого клиентского бота.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Не менять без повторной регистрации всех webhook.
WEBHOOK_MASTER_SECRET=

# Адаптивная пауза пустого outbox; commit нового сообщения будит его сразу.
OUTBOX_IDLE_MIN_SECONDS=10
OUTBOX_IDLE_MAX_SECONDS=30

# ===== Безопасность =====
# ОБЯЗАТЕЛЬНО: случайная строка ≥16 символов, иначе сервис не стартует.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# --- Ключи шифрования персональных данных (см. app/core/phones.py) ---
# Телефоны веб-клиентов хранятся зашифрованными, а ищутся по HMAC-индексу.
# PHONE_ENC_KEY — выделенный ключ (версия v1). Пусто — используется
# исторический ключ, выведенный из JWT_SECRET (версия jwt).
#
# ВАЖНО для существующей базы: не задавайте PHONE_ENC_KEY «на ходу».
# Порядок: деплой кода -> добавить PHONE_ENC_KEY и PHONE_KEYRING со старым
# ключом -> python -m scripts.migrate_phone_keys --dry-run -> --apply ->
# --verify -> и только потом убирать связку и ротировать JWT_SECRET.
# Ключ хранить ОТДЕЛЬНО от резервных копий: копия зашифрована им же.
PHONE_ENC_KEY=
# Связка прежних ключей на время перехода: ver:secret,ver:secret
# Например: jwt:<прежнее значение JWT_SECRET>
PHONE_KEYRING=
# Именованные неизменяемые версии ключей телефонов (предпочтительно вместо
# PHONE_ENC_KEY/PHONE_KEYRING): `v1:secret,v2:secret`. Версия — метка,
# которая НИКОГДА не меняет смысл.
#
# Два РАЗНЫХ секрета под одной версией = приложение не стартует. Это
# касается и дубля внутри самой строки (`v1:A,v1:B`), и конфликта с
# PHONE_ENC_KEY (он и есть версия v1). Замена ключа — это НОВАЯ версия:
# `v1:<старый>,v2:<новый>` + PHONE_ACTIVE_KEY_VERSION=v2. Единственное
# допустимое перекрытие — историческая версия jwt при ротации JWT_SECRET.
PHONE_KEYS=
# Какой версией шифровать НОВЫЕ записи (напр. v2). Пусто — обратно
# совместимо: v1 при заданном PHONE_ENC_KEY, иначе исторический jwt.
PHONE_ACTIVE_KEY_VERSION=
# Версии, которые МОГУТ быть в данных и обязаны быть читаемы. Если хоть
# одна недоступна — новые веб-клиенты НЕ создаются (иначе завели бы дубль
# под нечитаемым индексом). Пусто — ожидается только историческая jwt.
PHONE_LEGACY_VERSIONS=
# Ключ шифрования токенов Telegram/VK клубов (см. app/core/bot_tokens.py).
# Отдельный от JWT и от ключа телефонов. Обязателен для Pro: без него
# токен клуба нельзя сохранить. Хранить ВНЕ Railway и вне резервных копий.
BOT_TOKEN_ENC_KEY=
# Связка прежних ключей токенов на время замены: ver:secret,ver:secret
BOT_TOKEN_KEYRING=
# Именованные версии ключей токенов ботов (аналог PHONE_KEYS): `v1:secret,...`
# Те же правила: разные секреты под одной версией (в т.ч. конфликт с
# BOT_TOKEN_ENC_KEY) — ошибка конфигурации. Замена ключа = новая версия.
BOT_TOKEN_KEYS=
BOT_TOKEN_ACTIVE_KEY_VERSION=
# Ключ шифрования резервных копий (см. app/services/backup.py). Копия
# уходит в Telegram — без ключа она не отправляется вовсе. Хранить
# ОТДЕЛЬНО от самих копий: ключ рядом с копией не защищает ни от чего.
BACKUP_ENC_KEY=
# Кому доверять заголовок X-Forwarded-For (uvicorn --forwarded-allow-ips).
# Пусто — не доверять никому: подделать адрес нельзя, но за обратным прокси
# все посетители будут выглядеть одинаково и лимит запросов станет общим.
# На Railway адрес прокси динамический — там нужно "*".
TRUSTED_PROXIES=
# Одноразовое разрешение на 'alembic stamp head' для legacy-базы, у которой
# схему создал create_all до появления alembic (см. app/db/pre_migrate.py).
# В обычном деплое НЕ задавать: без флага упавшая миграция честно
# останавливает выкат. Ставить 1 только осознанно и снимать после успеха.
ALLOW_LEGACY_STAMP=




ADMIN_API_TOKEN=
# dev-вход в админку без Telegram — только для отладки
ADMIN_DEV_LOGIN=false

# ===== Платежи (ЮKassa) =====
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Stripe (каркас)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== Публичный адрес (для webhook и абсолютных ссылок) =====
# Нужен и для QR-кодов, и для ссылки управления, которую администратор
# выдаёт клиенту: она отдаётся полным URL именно отсюда, а не из заголовка
# Host запроса (его задаёт клиент). Не задан — выдача ссылки вернёт ошибку
# с просьбой настроить эту переменную. Только http(s).
PUBLIC_BASE_URL=

# ===== Прочее =====
TIMEZONE=Europe/Moscow
LOG_DIR=/data/logs

# ===== SaaS: биллинг-алерты (мультиклиент) =====
# Ваш Telegram ID — сюда придёт сводка по клубам с истекающей/истёкшей
# оплатой. Пусто — сводка не шлётся.
PLATFORM_OWNER_TG_ID=
# Контакт для продления, подставляется в уведомление клиенту (например
# "@ваш_ник"). Пусто — общая формулировка "свяжитесь с администрацией".
PLATFORM_SUPPORT_CONTACT=
