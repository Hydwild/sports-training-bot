# ═══════════════════════════════════════════════════════════
#  Переменные окружения для развёртывания на Railway
#  Заполни значения справа от = и вставь в Railway (Variables)
# ═══════════════════════════════════════════════════════════

# --- Редакция ---
EDITION=lite

# --- База данных (SQLite, отдельный Postgres не нужен) ---
# Требует Volume, примонтированный на /data (см. инструкцию)
DATABASE_URL=sqlite+aiosqlite:////data/badminton.db

# --- Telegram (обязательно) ---
# Токен бота от @BotFather
TG_TOKEN=
TG_MODE=polling

# --- ВКонтакте (заполни, если нужен VK-бот) ---
# Токен сообщества с правами: сообщения + управление + стена
VK_TOKEN=
RUN_VK_POLLING=true

# --- Секреты (любые случайные строки) ---
JWT_SECRET=

# --- Ключи шифрования персональных данных (см. app/core/phones.py) ---
# Телефоны веб-клиентов хранятся зашифрованными, а ищутся по HMAC-индексу.
# PHONE_ENC_KEY — выделенный ключ (версия v1). Пусто — используется
# исторический ключ, выведенный из JWT_SECRET (версия jwt).
#
# ВАЖНО для существующей базы: не задавайте PHONE_ENC_KEY «на ходу».
# Порядок: деплой кода -> добавить PHONE_ENC_KEY и PHONE_KEYRING со старым
# ключом -> python -m scripts.migrate_phone_keys --dry-run -> --apply ->
# --verify -> и только потом убирать связку и ротировать JWT_SECRET.
# Ключ хранить ОТДЕЛЬНО от резервных копий: копия зашифрована им же.
PHONE_ENC_KEY=
# Связка прежних ключей на время перехода: ver:secret,ver:secret
# Например: jwt:<прежнее значение JWT_SECRET>
PHONE_KEYRING=
# Ключ шифрования токенов Telegram/VK клубов (см. app/core/bot_tokens.py).
# Отдельный от JWT и от ключа телефонов. Обязателен для Pro: без него
# токен клуба нельзя сохранить. Хранить ВНЕ Railway и вне резервных копий.
BOT_TOKEN_ENC_KEY=
# Связка прежних ключей токенов на время замены: ver:secret,ver:secret
BOT_TOKEN_KEYRING=
# Ключ шифрования резервных копий (см. app/services/backup.py). Копия
# уходит в Telegram — без ключа она не отправляется вовсе. Хранить
# ОТДЕЛЬНО от самих копий: ключ рядом с копией не защищает ни от чего.
BACKUP_ENC_KEY=
# Кому доверять заголовок X-Forwarded-For (uvicorn --forwarded-allow-ips).
# Пусто — не доверять никому: подделать адрес нельзя, но за обратным прокси
# все посетители будут выглядеть одинаково и лимит запросов станет общим.
# На Railway адрес прокси динамический — там нужно "*".
TRUSTED_PROXIES=



ADMIN_API_TOKEN=

# --- Прочее ---
TIMEZONE=Europe/Moscow
LOG_DIR=/data/logs
PORT=8080
