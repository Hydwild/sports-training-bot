# ═══════════════════════════════════════════════════════════
#  Переменные окружения для развёртывания на Railway
#  Заполни значения справа от = и вставь в Railway (Variables)
# ═══════════════════════════════════════════════════════════

# --- Редакция ---
EDITION=lite

# --- База данных (SQLite, отдельный Postgres не нужен) ---
# Требует Volume, примонтированный на /data (см. инструкцию)
DATABASE_URL=sqlite+aiosqlite:////data/badminton.db

# --- Telegram (обязательно) ---
# Токен бота от @BotFather
TG_TOKEN=
TG_MODE=polling

# --- ВКонтакте (заполни, если нужен VK-бот) ---
# Токен сообщества с правами: сообщения + управление + стена
VK_TOKEN=
RUN_VK_POLLING=true

# --- Секреты (любые случайные строки) ---
JWT_SECRET=
ADMIN_API_TOKEN=

# --- Прочее ---
TIMEZONE=Europe/Moscow
LOG_DIR=/data/logs
PORT=8080
